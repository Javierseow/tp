@startuml
hide footbox

actor User
participant ":FitLogger" as Main
participant ":Parser" as Parser
participant "command:DeleteCommand" as Cmd
participant ":WorkoutList" as Workouts
participant ":Workout" as Workout
participant ":Storage" as Storage
participant ":Ui" as Ui

User -> Main : delete 3
activate Main

Main -> Parser : parse("delete 3", workouts, dictionary)
activate Parser
Parser --> Main : new DeleteCommand(3)
deactivate Parser

Main -> Cmd : execute(storage, workouts, ui, profile)
activate Cmd

Cmd -> Workouts : getSize()
alt valid index within range
  Cmd -> Workouts : getWorkoutAtIndex(2)
  Workouts --> Cmd : workout
  Cmd -> Workout : getDescription()
  Workout --> Cmd : deletedWorkoutName
  note right of Cmd
    Description is read from the
    target workout before deletion.
  end note
  Cmd -> Workouts : deleteWorkout(2)
  Cmd -> Workouts : getWorkouts()
  Workouts --> Cmd : workoutList
  Cmd -> Storage : saveData(workoutList, profile)
  alt save succeeds
    Storage --> Cmd : true
    Cmd -> Ui : showMessage("Deleted workout: ...")
  else save fails
    Storage --> Cmd : false
    Cmd -> Ui : showError("Failed to save workouts to disk...")
  end
else out-of-range index
  Cmd -> Ui : showMessage("Invalid workout index: ...")
end

Cmd --> Main
deactivate Cmd
deactivate Main
@enduml
