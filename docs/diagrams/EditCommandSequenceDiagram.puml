@startuml
hide footbox

actor User
participant ":FitLogger" as Main
participant ":Parser" as Parser
participant "command:EditCommand" as Cmd
participant ":WorkoutList" as Workouts
participant ":StrengthWorkout" as StrengthWorkout
participant ":Storage" as Storage
participant ":Ui" as Ui

User -> Main : edit 2 reps/10
activate Main

Main -> Parser : parse("edit 2 reps/10", workouts, dictionary)
activate Parser
Parser --> Main : new EditCommand(2, "reps", "10")
deactivate Parser

Main -> Cmd : execute(storage, workouts, ui, profile)
activate Cmd

alt invalid index
	Cmd -> Workouts : getSize()
	Cmd -> Ui : showMessage("Invalid workout index: ...")
else valid index
	Cmd -> Workouts : getWorkoutAtIndex(1)
	alt valid field and value
		Cmd -> Cmd : dispatch field (reps)
		Cmd -> StrengthWorkout : setReps(10)
		Cmd -> Workouts : getWorkouts()
		Workouts --> Cmd : workoutList
		Cmd -> Storage : saveData(workoutList, profile)
		alt save succeeds
			Storage --> Cmd : true
			Cmd -> Ui : showMessage("Updated workout 2: ...")
		else save fails
			Storage --> Cmd : false
			Cmd -> Ui : showError("Failed to save workouts to disk...")
		end
	else invalid field or value
		Cmd -> Ui : showMessage("Validation / field error")
	end
end

Cmd --> Main
deactivate Cmd
deactivate Main
@enduml
